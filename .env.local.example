# Supabase — from supabase.com > your project > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Strava — from strava.com/settings/api
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=abc123...
# Your Strava athlete ID (find it at strava.com/athletes/YOUR_ID or via /api/strava/me)
STRAVA_ATHLETE_ID=12345678

# Strava webhook verify token — any random string you choose
STRAVA_WEBHOOK_VERIFY_TOKEN=my-secret-verify-token-123

# Session signing — any long random string (generate with: openssl rand -hex 32)
SESSION_SECRET=abc123def456...

# App URL — your Vercel URL (or http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Anthropic Claude API — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
